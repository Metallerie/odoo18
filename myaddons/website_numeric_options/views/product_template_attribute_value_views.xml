<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_attribute_view_form_inherit_numeric_options" model="ir.ui.view">
        <field name="name">product.attribute.form.numeric.options</field>
        <field name="model">product.attribute</field>
        <field name="inherit_id" ref="product.product_attribute_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='value_ids']/list/field[@name='name']" position="after">

                <field name="value_input_type" string="Type"/>

                <field name="numeric_type"
                       invisible="value_input_type != 'numeric'"/>

                <field name="calc_operation"
                       invisible="value_input_type != 'computed'"/>

                <field name="calc_operand_1_id"
                       invisible="value_input_type != 'computed'"
                       options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>

                <field name="calc_operand_2_id"
                       invisible="value_input_type != 'computed'"
                       options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"/>

            </xpath>

        </field>
    </record>

</odoo>
