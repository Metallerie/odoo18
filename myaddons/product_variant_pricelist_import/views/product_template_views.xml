
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_variant_pricelist_import" model="ir.ui.view">
        <field name="name">product.template.form.variant.pricelist.import</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_variant_pricelist_import_wizard"
                    type="object"
                    string="Import variantes + pricelist"
                    class="btn btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>
