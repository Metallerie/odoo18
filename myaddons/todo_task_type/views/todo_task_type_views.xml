<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_todo_task_type_list" model="ir.ui.view">
        <field name="name">todo.task.type.list</field>
        <field name="model">todo.task.type</field>
        <field name="arch" type="xml">
            <list string="Types de tâches">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_todo_task_type_form" model="ir.ui.view">
        <field name="name">todo.task.type.form</field>
        <field name="model">todo.task.type</field>
        <field name="arch" type="xml">
            <form string="Type de tâche">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

     <record id="action_todo_task_type" model="ir.actions.act_window">
        <field name="name">Types de tâches</field>
        <field name="res_model">todo.task.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_todo_task_type"
        name="Types de tâches"
        parent="project_todo.menu_todo_todos"
        action="action_todo_task_type"
        sequence="20"/>

</odoo>
