<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form_todo_type" model="ir.ui.view">
        <field name="name">project.task.form.todo.type</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="todo_type_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_search_todo_type" model="ir.ui.view">
        <field name="name">project.task.search.todo.type</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="todo_type_id"/>
                <filter
                    string="Par type de tâche"
                    name="group_by_todo_type"
                    context="{'group_by': 'todo_type_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
