<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <data noupdate="1">
        <record id="purchase.email_template_edi_purchase" model="mail.template">
            <field name="body_html" type="html"><![CDATA[
<div>
    <p>Bonjour <t t-out="object.partner_id.name or ''"/></p>

    <p>
        Vous trouverez ci-joint le bon de commande
        <strong><t t-out="object.name or ''"/></strong>
        avec la référence :
        <t t-out="object.partner_ref or ''"/>
        pour un montant de
        <strong><t t-out="format_amount(object.amount_total, object.currency_id)"/></strong>
        de la part de
        <t t-out="object.company_id.name or ''"/>.
    </p>

    <p>
        La réception est prévue le
        <strong><t t-out="format_date(object.date_planned)"/></strong>.
    </p>

    <t t-out="object._get_mail_line_details_html()"/>

    <p>Pourriez-vous confirmer la bonne réception de cette commande ?</p>
</div>
            ]]></field>
        </record>

    </data>
</odoo>
