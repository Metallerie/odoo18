<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_attribute_view_form_sale_calculated_options" model="ir.ui.view">
        <field name="name">product.attribute.form.sale.calculated.options</field>
        <field name="model">product.attribute</field>
        <field name="inherit_id" ref="product.product_attribute_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">
                <group string="Options calculées">
                    <field name="is_calculated"/>
                    <field name="calc_method" invisible="not is_calculated"/>
                    <field name="use_as_order_qty" invisible="not is_calculated"/>
                    <field name="affect_price" invisible="not is_calculated"/>
                    <field name="show_result_in_cart" invisible="not is_calculated"/>
                    <field name="result_readonly" invisible="not is_calculated"/>

                    <field name="calculation_line_ids" invisible="not is_calculated">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="source_attribute_id"/>
                            <field name="role"/>
                        </list>
                    </field>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
