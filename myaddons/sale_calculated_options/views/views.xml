<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_attribute_view_form_sale_calculated_options" model="ir.ui.view">
        <field name="name">product.attribute.form.sale.calculated.options</field>
        <field name="model">product.attribute</field>
        <field name="inherit_id" ref="product.product_attribute_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='value_ids']/list" position="inside">
                <field name="value_input_type"/>
                <field name="numeric_type"/>
                <field name="is_free_text"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <group string="Options calculées">
                    <field name="is_calculated"/>
                    <field name="calc_method" invisible="not is_calculated"/>
                    <field name="use_as_order_qty" invisible="not is_calculated"/>
                    <field name="affect_price" invisible="not is_calculated"/>
                    <field name="show_result_in_cart" invisible="not is_calculated"/>
                    <field name="result_readonly" invisible="not is_calculated"/>
                </group>
            </xpath>

        </field>
    </record>

    <record id="product_option_variable_view_list" model="ir.ui.view">
        <field name="name">product.option.variable.list</field>
        <field name="model">product.option.variable</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="variable_type"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="product_option_variable_view_form" model="ir.ui.view">
        <field name="name">product.option.variable.form</field>
        <field name="model">product.option.variable</field>
        <field name="arch" type="xml">
            <form string="Variable de calcul">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="variable_type"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_option_variable_action" model="ir.actions.act_window">
        <field name="name">Variables de calcul</field>
        <field name="res_model">product.option.variable</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="product_option_variable_menu"
        name="Variables de calcul"
        parent="sale.product_menu_catalog"
        action="product_option_variable_action"
        sequence="95"/>

    <record id="product_template_attribute_value_variable_view_list" model="ir.ui.view">
        <field name="name">product.template.attribute.value.variable.list</field>
        <field name="model">product.template.attribute.value.variable</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_tmpl_id" column_invisible="1"/>
                <field name="attribute_id" column_invisible="1"/>
                <field name="available_value_ids" column_invisible="1"/>
                <field name="value_id" domain="[('id', 'in', available_value_ids)]"/>
                <field name="variable_id"/>
                <field name="variable_code"/>
                <field name="variable_type"/>
                <field name="numeric_value" invisible="variable_type != 'numeric'"/>
                <field name="text_value" invisible="variable_type != 'text'"/>
            </list>
        </field>
    </record>

    <record id="product_template_attribute_value_variable_view_form" model="ir.ui.view">
        <field name="name">product.template.attribute.value.variable.form</field>
        <field name="model">product.template.attribute.value.variable</field>
        <field name="arch" type="xml">
            <form string="Variable de valeur">
                <sheet>
                    <group>
                        <field name="product_tmpl_id"/>
                        <field name="attribute_id"/>
                        <field name="available_value_ids" invisible="1"/>
                        <field name="value_id" domain="[('id', 'in', available_value_ids)]"/>
                        <field name="variable_id"/>
                        <field name="variable_code" readonly="1"/>
                        <field name="variable_type" readonly="1"/>
                        <field name="numeric_value" invisible="variable_type != 'numeric'"/>
                        <field name="text_value" invisible="variable_type != 'text'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_template_form_attribute_line_variables" model="ir.ui.view">
        <field name="name">product.template.form.attribute.line.variables</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='attribute_line_ids']/list" position="inside">
                <button name="action_open_value_variables"
                        type="object"
                        string="Variables"
                        class="btn-secondary"/>
            </xpath>

        </field>
    </record>

    <record id="product_template_form_sale_calculated_options" model="ir.ui.view">
        <field name="name">product.template.form.sale.calculated.options</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='attribute_line_ids']" position="after">
                <group string="Configuration des options calculées">
                    <field name="calculated_option_line_ids" context="{'default_product_tmpl_id': id}">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="calculated_attribute_id"/>
                            <field name="available_source_attribute_ids" column_invisible="1"/>
                            <field name="source_attribute_id"
                                   domain="[('id', 'in', available_source_attribute_ids)]"/>
                            <field name="source_value_input_type"/>
                            <field name="source_numeric_type"/>
                            <field name="source_is_free_text"/>
                            <field name="role"/>
                        </list>
                    </field>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
