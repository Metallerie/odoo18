<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_tree_quick_quote" model="ir.ui.view">
        <field name="name">sale.order.tree.quick.quote</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_open_quick_quote"
                            type="object"
                            string="Devis rapide"
                            class="btn-primary"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
