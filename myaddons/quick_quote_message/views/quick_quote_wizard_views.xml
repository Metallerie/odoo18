<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quick_quote_wizard_form" model="ir.ui.view">
        <field name="name">quick.quote.wizard.form</field>
        <field name="model">quick.quote.wizard</field>
        <field name="arch" type="xml">
            <form string="Devis rapide" create="false" edit="true" delete="false">
                <sheet>
                    <group>
                        <field name="currency_id" invisible="1"/>
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="quantity"/>
                                <field name="uom_name" readonly="1"/>
                                <field name="price_unit"/>
                                <field name="subtotal" readonly="1"/>
                                <field name="line_note" string="Ligne libre"/>
                            </list>
                        </field>
                    </group>

                    <group>
                        <field name="note" placeholder="Informations de fin"/>
                        <field name="amount_total" readonly="1"/>
                    </group>

                    <group>
                        <field name="generated_text" widget="copy" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_copy_placeholder"
                            type="object"
                            string="Copier"
                            class="btn-primary"/>
                    <button name="action_close"
                            type="object"
                            string="Fermer"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_quick_quote_wizard" model="ir.actions.act_window">
        <field name="name">Devis rapide</field>
        <field name="res_model">quick.quote.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
