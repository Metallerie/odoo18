<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quick_quote_wizard_form" model="ir.ui.view">
        <field name="name">quick.quote.wizard.form</field>
        <field name="model">quick.quote.wizard</field>
        <field name="arch" type="xml">
            <form string="Devis rapide" create="false" edit="true" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="pricelist_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                        </group>
                    </group>

                    <group string="Lignes devis">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="quantity"/>
                                <field name="uom_name" readonly="1"/>
                                <field name="price_unit"/>
                                <field name="subtotal" readonly="1"/>
                                <field name="in_stock"/>
                                <field name="cut_count"/>
                                <field name="cut_length_mm"/>
                                <field name="line_note" string="Ligne libre"/>
                            </list>
                        </field>
                    </group>

                    <group string="Informations de fin">
                        <field name="note" placeholder="Informations complémentaires"/>
                    </group>

                    <group string="Texte généré">
                        <field name="generated_text" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Fermer" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_quick_quote_wizard" model="ir.actions.act_window">
        <field name="name">Devis rapide</field>
        <field name="res_model">quick.quote.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
