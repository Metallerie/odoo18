<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Bouton Scan JSON -->
    <record id="view_move_form_inherit_docai_scan" model="ir.ui.view">
      <field name="name">account.move.form.inherit.docai.scan</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <xpath expr="//header" position="inside">
          <button name="action_docai_scan_json"
                  type="object"
                  string="Scan from JSON"
                  class="btn-secondary"
                  invisible="state != 'draft'"/>
        </xpath>
      </field>
    </record>

    <!-- Vue principale DocAI -->
    <record id="view_move_form_docai" model="ir.ui.view">
      <field name="name">account.move.form.docai</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">

        <!-- Champ visible à coup sûr avant les onglets -->
        <xpath expr="//field[@name='journal_id']" position="attributes">
        <attribute name="invisible">state == 'draft'</attribute>
        </xpath>
        <xpath expr="//sheet/notebook" position="before">
          <group string="Requalification comptable">
            <field name="x_target_journal_code" invisible="state != 'draft'"/>
          </group>
          <group string="Retrait / Dépôt d'espèces" invisible="move_type != 'entry'">
            <group>
              <field name="docai_cash_journal_id" readonly="state != 'draft' or docai_cash_transfer_done"/>
              <field name="docai_bank_journal_id" readonly="state != 'draft' or docai_cash_transfer_done"/>
              <field name="docai_transfer_account_id" readonly="state != 'draft' or docai_cash_transfer_done"/>
            </group>
            <group>
              <field name="docai_transfer_reference" readonly="1"/>
              <field name="docai_linked_move_id" readonly="1"/>
              <field name="docai_transfer_origin_id" readonly="1"/>
              <field name="docai_cash_transfer_done" invisible="1"/>
            </group>
          </group>
        </xpath>

        <!-- Onglets DocAI -->
        <xpath expr="//sheet/notebook" position="inside">
          <page string="DocAI (Simplifié)">
            <field name="docai_json" widget="text" readonly="1" nolabel="1"/>
          </page>
          <page string="DocAI (Complet)">
            <field name="docai_json_raw" widget="text" readonly="1" nolabel="1"/>
          </page>
        </xpath>

        <!-- Boutons DocAI -->
        <xpath expr="//header" position="inside">
          <button name="action_docai_analyze_attachment"
                  type="object"
                  string="Analyser PDF avec DocAI"
                  class="btn-primary"
                  invisible="state != 'draft'"/>
          <button name="action_docai_refresh_json"
                  type="object"
                  string="Rafraîchir JSON"
                  class="btn-secondary"
                  invisible="state != 'draft'"/>
          <button name="action_docai_download_json_raw"
                  type="object"
                  string="⬇ Télécharger JSON Complet"
                  class="btn-secondary"/>
          <button name="action_docai_download_json_min"
                  type="object"
                  string="⬇ Télécharger JSON Simplifié"
                  class="btn-secondary"/>

          <button name="action_docai_process_cash_transfer"
                  type="object"
                  string="Retrait / Dépôt d'espèces"
                  class="oe_highlight"
                  invisible="state != 'draft' or docai_cash_transfer_done"/>
          <button name="action_docai_open_linked_move"
                  type="object"
                  string="Voir la pièce liée"
                  class="btn-secondary"
                  invisible="not docai_linked_move_id and not docai_transfer_origin_id"/>

        </xpath>

      </field>
    </record>

    <!-- Onglet OCR JSON -->
    <record id="view_move_form_json_tab" model="ir.ui.view">
      <field name="name">account.move.form.json.tab</field>
      <field name="model">account.move</field>
      <field name="inherit_id" ref="account.view_move_form"/>
      <field name="arch" type="xml">
        <xpath expr="//sheet/notebook" position="inside">
          <page string="OCR JSON">
            <field name="docai_json" widget="text" readonly="1" nolabel="1"/>
          </page>
        </xpath>
      </field>
    </record>

  </data>
</odoo>
