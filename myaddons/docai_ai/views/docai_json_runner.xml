<odoo>
  <!-- Onglets JSON DocAI -->
  <record id="view_move_form_json" model="ir.ui.view">
    <field name="name">account.move.form.json</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

      <xpath expr="//sheet/notebook" position="inside">

        <page string="DocAI (Simplifié)">
          <field name="docai_json"
                 widget="text"
                 readonly="1"
                 nolabel="1"/>
        </page>

        <page string="DocAI (Complet)">
          <field name="docai_json_raw"
                 widget="text"
                 readonly="1"
                 nolabel="1"/>
        </page>

      </xpath>

    </field>
  </record>

  <!-- Boutons DocAI -->
  <record id="view_move_form_inherit_docai_analyze" model="ir.ui.view">
    <field name="name">account.move.form.inherit.docai.analyze</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

      <xpath expr="//header" position="inside">

        <!-- Analyse Google Document AI : factures, tickets et pièces comptables -->
        <button name="action_docai_analyze_attachment"
                type="object"
                string="Analyser PDF avec DocAI"
                class="oe_highlight"
                invisible="state != 'draft'"/>

        <!-- Reconstruit uniquement la partie bancaire depuis le JSON complet -->
        <button name="action_docai_enrich_bank_receipt"
                type="object"
                string="Enrichir récépissé bancaire"
                class="btn-secondary"
                invisible="move_type != 'entry' or state != 'draft' or not docai_json_raw"/>

        <!-- Crée débit/crédit dans la pièce comptable -->
        <button name="action_docai_create_bank_receipt_move_lines"
                type="object"
                string="Créer écriture bancaire"
                class="btn-secondary"
                invisible="move_type != 'entry' or state != 'draft' or not docai_json"/>

      </xpath>

    </field>
  </record>
</odoo>
